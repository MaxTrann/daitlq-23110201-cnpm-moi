<%- include('partials/header', { title: 'Đăng ký tài khoản' }); %>

<div class="row justify-content-center">
  <div class="col-lg-5 col-md-7">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4">
        <h3 class="mb-2">Đăng ký tài khoản</h3>
        <p class="text-muted mb-4">Điền thông tin để tạo tài khoản mới.</p>

        <div class="alert alert-danger d-none" id="registerError"></div>
        <div class="alert alert-success d-none" id="registerSuccess"></div>

        <form id="registerForm">
          <div class="form-group">
            <label>Username</label>
            <input class="form-control" name="username" type="text" placeholder="Tên đăng nhập" required />
          </div>
          <div class="form-group">
            <label>Email</label>
            <input class="form-control" name="email" type="email" placeholder="email@domain.com" required />
          </div>
          <div class="form-group">
            <label>Mật khẩu</label>
            <div class="input-group">
              <input class="form-control" name="password" type="password" required />
              <div class="input-group-append">
                <button class="btn btn-outline-secondary" type="button" data-toggle-password="password" aria-label="Hiển thị mật khẩu">
                  <span data-eye-open>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </span>
                  <span class="d-none" data-eye-closed>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20C5 20 1 12 1 12a21.77 21.77 0 0 1 5.06-6.94"></path>
                      <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a21.8 21.8 0 0 1-3.27 4.85"></path>
                      <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"></path>
                      <path d="M1 1l22 22"></path>
                    </svg>
                  </span>
                </button>
              </div>
            </div>
          </div>
          <div class="form-group">
            <label>Xác nhận mật khẩu</label>
            <div class="input-group">
              <input class="form-control" name="confirmPassword" type="password" required />
              <div class="input-group-append">
                <button class="btn btn-outline-secondary" type="button" data-toggle-password="confirmPassword" aria-label="Hiển thị mật khẩu xác nhận">
                  <span data-eye-open>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </span>
                  <span class="d-none" data-eye-closed>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20C5 20 1 12 1 12a21.77 21.77 0 0 1 5.06-6.94"></path>
                      <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a21.8 21.8 0 0 1-3.27 4.85"></path>
                      <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"></path>
                      <path d="M1 1l22 22"></path>
                    </svg>
                  </span>
                </button>
              </div>
            </div>
          </div>
          <div class="form-group d-flex align-items-center">
            <input class="form-control mr-2" name="verificationCode" type="text" placeholder="Mã xác thực" maxlength="5" required style="max-width: 120px;" />
            <button class="btn btn-outline-primary" type="button" id="sendCodeButton">Nhận mã</button>
          </div>
          <button class="btn btn-primary btn-block" type="submit" id="registerSubmitButton">Đăng ký</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="/js/register.js"></script>
<%- include('partials/footer'); %>
