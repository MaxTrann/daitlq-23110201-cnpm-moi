<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đặt lại mật khẩu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .container {
            margin-top: 100px;
            max-width: 500px;
            background: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>

<body>
    <div class="container">
        <h2 class="text-center mb-4">Đặt lại mật khẩu</h2>

        <% if(locals.error) { %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
            <% } %>

                <div class="alert alert-info">
                    Mã OTP đã được gửi đến email của bạn. Vui lòng kiểm tra hộp thư (và thư mục rác).
                </div>

                <form action="/reset-password" method="POST">
                    <div class="form-group">
                        <label for="email">Email:</label>
                        <input type="email" class="form-control" id="email" name="email"
                            value="<%= locals.email || '' %>" readonly required>
                    </div>
                    <div class="form-group">
                        <label for="otp">Mã OTP (6 số):</label>
                        <input type="text" class="form-control" id="otp" name="otp" required placeholder="Nhập mã OTP">
                    </div>
                    <div class="form-group">
                        <label for="newPassword">Mật khẩu mới:</label>
                        <input type="password" class="form-control" id="newPassword" name="newPassword" required
                            placeholder="Nhập mật khẩu mới">
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Xác nhận mật khẩu mới:</label>
                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required
                            placeholder="Nhập lại mật khẩu mới">
                    </div>
                    <button type="submit" class="btn btn-success btn-block">Đổi mật khẩu</button>
                </form>
    </div>
</body>

</html>