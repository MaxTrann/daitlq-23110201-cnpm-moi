<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= typeof title !=='undefined' ? title : 'Ứng dụng đặt lịch khám CarePLus' %>
    </title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <script src="/js/auth.js"></script>
</head>

<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <a class="navbar-brand" href="/">CarePLus</a>
        <div class="navbar-nav flex-row align-items-center w-100">
            <a class="nav-item nav-link text-white px-3" href="/home">Trang chủ</a>
            <a class="nav-item nav-link text-white px-3" href="/about">Giới thiệu</a>
            <div class="ml-auto d-flex align-items-center">
                <a class="btn btn-light btn-sm mr-2" href="/login" id="loginNavButton">Đăng nhập</a>
                <a class="btn btn-outline-light btn-sm mr-2" href="/register" id="registerNavButton">Đăng ký</a>
                <div class="dropdown d-none" id="userNavDropdown">
                    <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" data-toggle="dropdown"
                        aria-expanded="false">
                        <span id="navUserLabel">Tài khoản</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-right">
                        <a class="dropdown-item d-none" href="/user/profile" id="userProfileNavLink">Trang cá nhân</a>
                        <a class="dropdown-item d-none" href="/user/profile/edit" id="userProfileEditNavLink">Chỉnh sửa hồ sơ</a>
                        <a class="dropdown-item d-none" href="/get-crud" id="adminUsersNavLink">Quản lý người dùng</a>
                        <button class="dropdown-item text-danger" type="button" id="logoutButton">Đăng xuất</button>
                    </div>
                </div>
            </div>
        </div>
     </div>
    </nav>
    <main class="container pb-5">
