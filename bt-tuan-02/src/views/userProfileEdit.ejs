<%- include('partials/header', { title: 'Chỉnh sửa hồ sơ' }); %>

<div data-auth-required="true" data-auth-role="user">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h3 class="mb-0">Chỉnh sửa hồ sơ</h3>
      <div class="text-muted">Cập nhật thông tin cá nhân của bạn.</div>
    </div>
    <div>
      <a class="btn btn-outline-secondary" href="/user/profile">Quay lại trang cá nhân</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
      <div class="alert alert-danger d-none" id="profileUpdateError"></div>
      <div class="alert alert-success d-none" id="profileUpdateSuccess"></div>

      <form id="userProfileForm">
        <div class="form-row">
          <div class="form-group col-md-6">
            <label>Username *</label>
            <input class="form-control" name="username" type="text" required />
          </div>
          <div class="form-group col-md-6">
            <label>Email *</label>
            <input class="form-control" name="email" type="email" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group col-md-6">
            <label>Họ</label>
            <input class="form-control" name="firstName" type="text" />
          </div>
          <div class="form-group col-md-6">
            <label>Tên</label>
            <input class="form-control" name="lastName" type="text" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group col-md-8">
            <label>Địa chỉ</label>
            <input class="form-control" name="address" type="text" />
          </div>
          <div class="form-group col-md-4">
            <label>Giới tính</label>
            <select class="form-control" name="gender">
              <option value="">—</option>
              <option value="1">Nam</option>
              <option value="0">Nữ</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group col-md-6">
            <label>Số điện thoại</label>
            <input class="form-control" name="phone" type="text" />
          </div>
          <div class="form-group col-md-6">
            <label>Mật khẩu mới</label>
            <input class="form-control" name="password" type="password" minlength="6" />
            <small class="text-muted">Để trống nếu chưa muốn đổi mật khẩu.</small>
          </div>
        </div>

        <div class="d-flex justify-content-end">
          <button class="btn btn-primary" type="submit">Lưu hồ sơ</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/userProfileEdit.js"></script>
<%- include('partials/footer'); %>
