<%- include('partials/header', { title: 'Đăng nhập' }); %>

<div class="row justify-content-center">
  <div class="col-lg-5 col-md-7">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4">
        <h3 class="mb-2">Đăng nhập</h3>
        <p class="text-muted mb-4">Sử dụng email hoặc username cùng mật khẩu để truy cập hệ thống.</p>

        <div class="alert alert-danger d-none" id="loginError"></div>
        <div class="alert alert-success d-none" id="loginSuccess"></div>

        <form id="loginForm">
          <div class="form-group">
            <label>Email hoặc username</label>
            <input class="form-control" name="login" type="text" placeholder="email@domain.com hoặc username" required />
          </div>

          <div class="form-group">
            <label>Mật khẩu</label>
            <input class="form-control" name="password" type="password" required />
          </div>

          <button class="btn btn-primary btn-block" type="submit" id="loginSubmitButton">Đăng nhập</button>

          <div class="d-flex justify-content-between align-items-center">
            <a href="/forgot-password">Quên mật khẩu?</a>
            <a href="/register">Đăng ký tài khoản</a>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>

<script src="/js/login.js"></script>
<%- include('partials/footer'); %>
