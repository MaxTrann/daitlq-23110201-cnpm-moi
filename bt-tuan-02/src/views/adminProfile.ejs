<%- include('partials/header', { title: 'Hồ sơ quản trị viên' }); %>

<div data-auth-required="true" data-auth-role="admin">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h3 class="mb-0">Hồ sơ quản trị viên</h3>
      <div class="text-muted">Thông tin tài khoản admin hiện tại và lối vào khu vực quản trị.</div>
    </div>
    <div>
      <a class="btn btn-primary" href="/get-crud">Vào trang quản lý người dùng</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <strong>Username</strong>
          <div id="profileUsername" class="text-muted">Đang tải...</div>
        </div>
        <div class="col-md-6 mb-3">
          <strong>Email</strong>
          <div id="profileEmail" class="text-muted">Đang tải...</div>
        </div>
        <div class="col-md-6 mb-3">
          <strong>Họ tên</strong>
          <div id="profileFullName" class="text-muted">Đang tải...</div>
        </div>
        <div class="col-md-6 mb-3">
          <strong>Vai trò</strong>
          <div id="profileRole" class="text-muted">Đang tải...</div>
        </div>
        <div class="col-md-6 mb-3">
          <strong>Trạng thái</strong>
          <div id="profileStatus" class="text-muted">Đang tải...</div>
        </div>
        <div class="col-md-6 mb-3">
          <strong>Lần đăng nhập gần nhất</strong>
          <div id="profileLastLogin" class="text-muted">Đang tải...</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/adminProfile.js"></script>
<%- include('partials/footer'); %>
