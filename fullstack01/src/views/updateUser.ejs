<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update User</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
    />
    <style>
      body {
        background: linear-gradient(135deg, #f4f7fb, #e8eef7);
        min-height: 100vh;
      }

      .form-wrapper {
        max-width: 900px;
        margin: 40px auto;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.08);
        padding: 32px;
      }

      .page-title {
        font-weight: 700;
        color: #1f3c88;
        margin-bottom: 8px;
      }

      .page-subtitle {
        color: #6c757d;
        margin-bottom: 24px;
      }

      .form-group label {
        font-weight: 600;
        color: #34495e;
      }

      .form-control {
        border-radius: 10px;
      }

      .btn-primary {
        border-radius: 10px;
        padding: 10px 24px;
        font-weight: 600;
      }

      .top-actions {
        margin-bottom: 20px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="form-wrapper">
        <h2 class="page-title">Update User</h2>
        <p class="page-subtitle">Chỉnh sửa thông tin người dùng</p>

        <div class="top-actions">
          <a href="/get-crud" class="btn btn-outline-primary"
            >Back To User List</a
          >
        </div>

        <form action="/put-crud" method="post">
          <input
            type="hidden"
            class="form-control"
            id="id"
            name="id"
            value="<%= user.id %>"
          />

          <div class="form-row">
            <div class="form-group col-md-6">
              <label for="firstName">First Name</label>
              <input
                type="text"
                class="form-control"
                id="firstName"
                name="firstName"
                value="<%= user.firstName %>"
              />
            </div>

            <div class="form-group col-md-6">
              <label for="lastName">Last Name</label>
              <input
                type="text"
                class="form-control"
                id="lastName"
                name="lastName"
                value="<%= user.lastName %>"
              />
            </div>
          </div>

          <div class="form-group">
            <label for="address">Address</label>
            <input
              type="text"
              class="form-control"
              id="address"
              name="address"
              placeholder="1234 Main St"
              value="<%= user.address %>"
            />
          </div>

          <button type="submit" class="btn btn-primary">Update</button>
        </form>
      </div>
    </div>
  </body>
</html>
