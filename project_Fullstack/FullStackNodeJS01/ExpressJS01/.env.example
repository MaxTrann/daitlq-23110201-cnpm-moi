PORT=8888
MONGO_DB_URL=mongodb://127.0.0.1:27017/medcare
MEDCARE_RESET_CATALOG=true
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=7d

# OTP
OTP_EXPIRE_MINUTES=10

# Rate limiting
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_OTP_MAX=8
RATE_LIMIT_FORGOT_MAX=5

# SMTP (optional - nếu không cấu hình, OTP in ra console khi dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="Campus Shop <your_email@gmail.com>"
